{
  "log": {
    "access": "none",
    "error": "C:\\Users\\admin\\Apps\\XHTTP\\error.log",
    "loglevel": "none",
    "dnsLog": true,
    "maskAddress": ""
  },
  "inbounds": [
    {
      "tag": "in-socks",
      "listen": "127.0.0.1",
      "port": 10808,
      "protocol": "mixed",
      "settings": {
        "auth": "noauth",
        "udp": true,
        "allowTransparent": false
      },
      "sniffing": {
        "enabled": false
      }
    }
  ],
  "outbounds": [
    {
      "tag": "out-proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "<VPS_IPv4>",
            "port": 443,
            "users": [
              {
                "id": "<Reality_UUID>",
                "flow": "xtls-rprx-vision",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "raw",
        "security": "reality",
        "realitySettings": {
          "serverName": "<Reality_Site>",
          "fingerprint": "chrome",
          "password": "<Reality_publicKey>",
          "shortId": "<Reality_shortId>",
          "spiderX": "/",
          "show": false
        },
        "rawSettings": {
          "header": {
            "type": "none"
          }
        }
      }
    }
  ],
  "routing": {
    "rules": [
      {
        "inboundTag": "in-socks",
        "outboundTag": "out-proxy"
      }
    ]
  }
}
